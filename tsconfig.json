{
  /* Visit https://aka.ms/tsconfig.json to read more about this file */
  "compilerOptions": {
    // https://devblogs.microsoft.com/typescript/announcing-typescript-5-7-beta/#path-rewriting-for-relative-paths
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,

    // additional recommended options for type stripping https://nodejs.org/api/typescript.html#type-stripping
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,

    "target": "es2023",

    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,
    "noImplicitOverride": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true, // enables importers to jump to source

    "forceConsistentCasingInFileNames": true
  }
}
